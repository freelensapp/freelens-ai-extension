{
  "name": "@freelensapp/ai-extension",
  "version": "0.6.0",
  "description": "AI capabilities for Freelens",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freelensapp/freelens-ai-extension.git",
    "directory": "."
  },
  "main": "out/main/index.js",
  "renderer": "out/renderer/index.js",
  "files": [
    "out/**/*"
  ],
  "engines": {
    "node": ">= 22.0.0",
    "freelens": "^1.4.0"
  },
  "copyright": "© 2025-2026 Freelens Authors",
  "license": "MIT",
  "author": {
    "name": "Freelens Authors",
    "email": "freelens@freelens.app"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "biome": "pnpm dlx @biomejs/biome@2.4.16",
    "biome:check": "pnpm biome check",
    "biome:fix": "pnpm biome check --fix",
    "biome:migrate": "pnpm biome migrate --write",
    "prettier": "pnpm dlx prettier@3.8.3",
    "prettier:check": "pnpm prettier --check .",
    "prettier:fix": "pnpm prettier --write .",
    "trunk": "pnpm dlx @trunkio/launcher@1.3.4",
    "trunk:check": "pnpm trunk check",
    "trunk:check:all": "pnpm trunk check --all",
    "trunk:fix": "pnpm trunk check --fix",
    "trunk:fix:all": "pnpm trunk check --fix --all",
    "lint": "pnpm lint:check",
    "lint:check": "pnpm \"/^(biome|prettier):check\\$/\"",
    "lint:fix": "pnpm \"/^(biome|prettier):fix\\$/\"",
    "knip": "pnpm dlx knip@6.11.0 --dependencies --no-gitignore",
    "knip:check": "pnpm \"/^knip:(development|production)\\$/\"",
    "knip:development": "pnpm knip",
    "knip:production": "pnpm knip --production --strict",
    "type:check": "tsc --noEmit -p tsconfig.json --composite false",
    "prebuild": "pnpm type:check",
    "build": "electron-vite build",
    "build:production": "VITE_PRESERVE_MODULES=false electron-vite build",
    "build:force": "electron-vite build",
    "bump-version": "pnpm version --no-commit-hooks --no-git-tag-version",
    "pack:dev": "pnpm bump-version prerelease && pnpm build:force && pnpm build && pnpm clean:tgz && pnpm pack && pnpm dlx shx@0.4.0 ls \"$PWD/*.tgz\"",
    "clean": "pnpm clean:out",
    "clean:dts": "pnpm dlx shx@0.4.0 rm -f \"src/**/*.d.scss.ts\"",
    "clean:node_modules": "pnpm dlx shx@0.4.0 rm -rf node_modules",
    "clean:out": "pnpm dlx shx@0.4.0 rm -rf out",
    "clean:tgz": "pnpm dlx shx@0.4.0 rm -f \"*.tgz\"",
    "clean:all": "pnpm \"/^clean:(dts|node_modules|out|tgz)\\$/\"",
    "postupdate": "pnpm biome:migrate"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.28.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@freelensapp/extensions": "^1.4.0",
    "@langchain/core": "^0.3.61",
    "@langchain/google-genai": "^0.2.13",
    "@langchain/langgraph": "^0.2.74",
    "@langchain/mcp-adapters": "^0.5.2",
    "@langchain/openai": "^0.5.15",
    "@types/node": "~24.0.0",
    "@types/react": "^17.0.87",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.6.0",
    "electron-vite": "^3.1.0",
    "loglevel": "^1.9.2",
    "lucide-react": "^0.510.0",
    "mobx": "6.13.7",
    "mobx-react": "7.6.0",
    "react": "17.0.2",
    "react-markdown": "^6.0.3",
    "react-select": "5.10.2",
    "react-syntax-highlighter": "^15.6.1",
    "sass": "^1.89.2",
    "typescript": "5.8.3",
    "vite": "^6.3.6",
    "vite-plugin-external": "^6.2.2",
    "zod": "^3.25.67"
  },
  "keywords": [
    "ai",
    "extension",
    "freelens",
    "freelensapp",
    "lens",
    "mcp",
    "openai",
    "openlens"
  ],
  "packageManager": "pnpm@10.12.4+sha512.5ea8b0deed94ed68691c9bad4c955492705c5eeb8a87ef86bc62c74a26b037b08ff9570f108b2e4dbd1dd1a9186fea925e527f141c648e85af45631074680184"
}
